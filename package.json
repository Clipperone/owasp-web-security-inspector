{
  "name": "owasp-web-security-inspector",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Browser extension for OWASP-inspired inspection and assessment of cookies, tokens, Set-Cookie responses, and HTTP security headers.",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "eslint": "eslint .",
    "test": "vitest run",
    "generate-icons": "node scripts/generate-icons.mjs",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^9.22.0",
    "@types/chrome": "^0.1.38",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^5.4.21",
    "vitest": "^4.1.1"
  }
}
